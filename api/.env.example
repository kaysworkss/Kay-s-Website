# ═══════════════════════════════════════════════════════
#  Àpótí Ọlọ́wẹ̀ — Puzzle Challenge API
#  Environment Variables · Kaysworks 2026
#
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ═══════════════════════════════════════════════════════

# ── Supabase ─────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API

# Your project URL — looks like https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co

# service_role key — has full DB access, bypasses RLS. Keep private.
# Found under: Settings → API → Project API keys → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Admin panel ──────────────────────────────────────────
# The password you type in the Admin ↗ login screen in the puzzle HTML
ADMIN_PASSWORD=choose-a-strong-password-here

# Secret used to sign admin JWT tokens — make this long and random
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret-string

# ── Server ───────────────────────────────────────────────
# Port the API listens on locally. Railway sets this automatically in production.
PORT=3001

# CORS — set to your actual domain in production to block other origins
# Use * for local development or open testing
ALLOWED_ORIGIN=https://kaysworks.com
