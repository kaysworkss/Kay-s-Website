{
  "version": 2,
  "functions": {
    "api/auction-config.js": {
      "maxDuration": 10
    },
    "api/game.js": {
      "maxDuration": 15
    },
    "api/admin.js": {
      "maxDuration": 30
    },
    "api/player.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/admin/login",              "destination": "/api/admin?action=login" },
    { "source": "/api/admin/challenges",         "destination": "/api/admin?action=challenges" },
    { "source": "/api/admin/challenge/:id",      "destination": "/api/admin?action=challenge&id=:id" },
    { "source": "/api/admin/challenge",          "destination": "/api/admin?action=challenge" },
    { "source": "/api/admin/upload-image",       "destination": "/api/admin?action=upload-image" },
    { "source": "/api/admin/wallets",            "destination": "/api/admin?action=wallets" },

    { "source": "/api/challenges",               "destination": "/api/game?action=challenges" },
    { "source": "/api/upcoming",                 "destination": "/api/game?action=upcoming" },
    { "source": "/api/challenge",                "destination": "/api/game?action=challenge" },
    { "source": "/api/score",                    "destination": "/api/game?action=score" },
    { "source": "/api/leaderboard/:id",          "destination": "/api/game?action=leaderboard&id=:id" },
    { "source": "/api/hall-of-fame",             "destination": "/api/game?action=hall-of-fame" },
    { "source": "/api/notify-outbid",            "destination": "/api/game?action=notify-outbid" },

    { "source": "/api/player/register",          "destination": "/api/player?action=register" },
    { "source": "/api/player/login",             "destination": "/api/player?action=login" },
    { "source": "/api/player/progress-save",     "destination": "/api/player?action=progress-save" },
    { "source": "/api/player/progress-load",     "destination": "/api/player?action=progress-load" },

    { "source": "/:name",                        "destination": "/:name.html" }
  ],
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma",        "value": "no-cache" },
        { "key": "Expires",       "value": "0" }
      ]
    },
    {
      "source": "/auction",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma",        "value": "no-cache" },
        { "key": "Expires",       "value": "0" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/auction(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-eval' 'unsafe-inline' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.resend.com https://*.infura.io https://*.alchemyapi.io https://*.alchemy.com https://eth-mainnet.g.alchemy.com https://cloudflare-ipfs.com https://ipfs.io https://gateway.pinata.cloud https://nftstorage.link https://arweave.net; img-src 'self' data: https: blob:; frame-ancestors 'none'"
        }
      ]
    },
    {
      "source": "/((?!auction).*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn-cgi.cloudflare.com https://va.vercel-scripts.com https://cdnjs.cloudflare.com https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; connect-src 'self' https://formspree.io https://vitals.vercel-insights.com https://*.supabase.co wss://*.supabase.co https://api.anthropic.com; worker-src 'self' blob:; frame-ancestors 'none'"
        }
      ]
    }
  ]
}
